{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "model": "opusplan",
  "effortLevel": "medium",
  "permissions": {
    "defaultMode": "bypassPermissions",
    "additionalDirectories": ["."],
    "allow": [
      "WebSearch", "WebFetch", "Read", "Write", "Edit", "Glob", "Grep", "Task", "TodoWrite",
      "Bash(mkdir:*)", "Bash(ls:*)", "Bash(cat:*)", "Bash(cp:*)", "Bash(mv:*)", "Bash(echo:*)",
      "Bash(find:*)", "Bash(wc:*)", "Bash(grep:*)", "Bash(sed:*)", "Bash(awk:*)", "Bash(head:*)",
      "Bash(tail:*)", "Bash(sort:*)", "Bash(python:*)", "Bash(python3:*)", "Bash(pip:*)", "Bash(git:*)"
    ],
    "deny": [
      "Read(../**)", "Edit(../**)", "Write(../**)",
      "Bash(rm:*)", "Bash(curl:*)", "Bash(ssh:*)", "Bash(scp:*)",
      "WebFetch(domain:mail.google.com)"
    ]
  },
  "hooks": {
    "SessionStart": [ { "hooks": [ { "type": "command", "command": "python \"$CLAUDE_PROJECT_DIR/.claude/hooks/log_activity.py\"", "timeout": 10 } ] } ],
    "UserPromptSubmit": [ { "hooks": [ { "type": "command", "command": "python \"$CLAUDE_PROJECT_DIR/.claude/hooks/log_activity.py\"", "timeout": 10 } ] } ],
    "PostToolUse": [ { "matcher": "*", "hooks": [ { "type": "command", "command": "python \"$CLAUDE_PROJECT_DIR/.claude/hooks/log_activity.py\"", "timeout": 10 } ] } ],
    "PostToolUseFailure": [ { "matcher": "*", "hooks": [ { "type": "command", "command": "python \"$CLAUDE_PROJECT_DIR/.claude/hooks/log_activity.py\"", "timeout": 10 } ] } ],
    "SubagentStop": [ { "hooks": [ { "type": "command", "command": "python \"$CLAUDE_PROJECT_DIR/.claude/hooks/log_activity.py\"", "timeout": 10 } ] } ],
    "Stop": [ { "hooks": [ { "type": "command", "command": "python \"$CLAUDE_PROJECT_DIR/.claude/hooks/log_activity.py\"", "timeout": 10 } ] } ],
    "SessionEnd": [ { "hooks": [ { "type": "command", "command": "python \"$CLAUDE_PROJECT_DIR/.claude/hooks/log_activity.py\"", "timeout": 10 } ] } ]
  }
}
